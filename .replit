modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "garland-maps-url"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dallas-maps-url"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "contact-details"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "website-tests"

[[workflows.workflow]]
name = "garland-maps-url"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node tests/garland-maps-url.test.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dallas-maps-url"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node tests/dallas-maps-url.test.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "contact-details"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node tests/contact-details.test.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "website-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/vv-auto-website test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 21511
externalPort = 3000

[[ports]]
localPort = 24691
externalPort = 3001

[[ports]]
localPort = 24692
externalPort = 3003

[userenv]

[userenv.shared]
DALLAS_MAPS_URL = "https://maps.app.goo.gl/iuW6oo7aA3FH7eG4A?g_st=ic"
DALLAS_WRITE_REVIEW_URL = "https://search.google.com/local/writereview?placeid=ChIJ025JNyKhToYRNRX5NXicpUQ"
GARLAND_MAPS_URL = "https://maps.app.goo.gl/SRFnqikpxGiZt1gm7?g_st=ic"

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-3efbbee6-5dd9-498f-a119-fb363d4979f9"
